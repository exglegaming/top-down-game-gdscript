; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Top Down Game"
run/main_scene="uid://dljyr1tf0br1x"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://i6akpsna6jdd"

[autoload]

Transition="*uid://cbcypdy7tuvnk"
Global="*uid://bqncih2vtyvto"
Music="*uid://r8x36hfn2xtf"
EventBus="*uid://6wf7jl6mnxq6"

[debug]

gdscript/warnings/untyped_declaration=2
gdscript/warnings/inferred_declaration=1

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://assets/": "green",
"res://extra/": "yellow",
"res://resources/": "purple",
"res://scenes/": "blue",
"res://scripts/": "orange",
"res://shaders/": "pink"
}

